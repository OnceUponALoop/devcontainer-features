{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Test: autogenerated for all features",
      "type": "shell",
      "command": "devcontainer",
      "args": [
        "features",
        "test",
        "--skip-scenarios",
        "."
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Test: feature autogenerated (prompt)",
      "type": "shell",
      "command": "devcontainer",
      "args": [
        "features",
        "test",
        "--skip-scenarios",
        "-f",
        "${input:feature}",
        "-i",
        "${input:baseImage}",
        "."
      ],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Test: feature scenarios (prompt)",
      "type": "shell",
      "command": "devcontainer",
      "args": [
        "features",
        "test",
        "--skip-autogenerated",
        "-f",
        "${input:feature}",
        "."
      ],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "feature",
      "type": "pickString",
      "description": "Feature to test",
      "options": [
        "proxy-ca-autotrust",
        "install-mise-copr"
      ],
      "default": "proxy-ca-autotrust"
    },
    {
      "id": "baseImage",
      "type": "pickString",
      "description": "Base image",
      "options": [
        "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
        "mcr.microsoft.com/devcontainers/base:debian-12",
        "ubuntu:24.04",
        "debian:12"
      ],
      "default": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04"
    }
  ]
}
