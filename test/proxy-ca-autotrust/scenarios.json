            ]
        },
        "features": {
            "proxy-ca-autotrust": {
                "tls_test_url": "https://127.0.0.1:18443",
                "cert_pattern": "",
                "key_fingerprint": "a04303e2582c3291e4ed1e5d9f26a5eac1da43cc83c683bee375f104e612da69"
            }
        }
    },
