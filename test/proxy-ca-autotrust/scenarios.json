{
    "extra_cert_only": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "runArgs": ["--security-opt", "label=disable"],
        "features": {
            "proxy-ca-autotrust": {
                "tls_test_url": "",
                "extra_certs": "https://letsencrypt.org/certs/isrgrootx1.pem"
            }
        }
    },
    "detect_issuer_pattern": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "runArgs": ["--security-opt", "label=disable"],
        "build": {
            "options": [
                "--network=host"
            ]
        },
        "features": {
            "proxy-ca-autotrust": {
                "tls_test_url": "https://127.0.0.1:18443",
                "cert_pattern": "O=Test Proxy Inc\\.",
                "key_fingerprint": ""
            }
        }
    },
    "detect_key_fingerprint": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
